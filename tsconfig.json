{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "node16",
    "outDir": "dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "strict": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "src/x402-standalone/**/*.ts",
    "test/fetch.ts",
    "test/mcp-x402-request-tool.ts",
    "src/index.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
