# =============================================================================
# GatePay MCP 环境配置示例
# =============================================================================

# -----------------------------------------------------------------------------
# 环境选择（test 或 prd，默认 prd）
# -----------------------------------------------------------------------------
# 设置为 test 使用测试环境，设置为 prd 或不设置使用生产环境
GATE_PAY_ENV=prd

# -----------------------------------------------------------------------------
# 用户凭证（根据使用的签名模式选择配置）
# -----------------------------------------------------------------------------

# 本地私钥模式 (local_private_key)
# EVM 链私钥（必须配置 EVM 或 SVM 至少一个）
# EVM_PRIVATE_KEY=your-evm-private-key-hex-with-or-without-0x-prefix

# Solana 链私钥（可选）
# SVM_PRIVATE_KEY=your-solana-private-key-base58

# Quick Wallet 模式 (quick_wallet)
# Quick Wallet API 密钥（可选）
# QUICK_WALLET_API_KEY=your-api-key

# Plugin Wallet 模式 (plugin_wallet)
# Plugin Wallet 访问令牌（必须配置才能使用插件钱包）
# PLUGIN_WALLET_TOKEN=your-plugin-wallet-token

# -----------------------------------------------------------------------------
# 高级配置：单独覆盖任何配置项
# -----------------------------------------------------------------------------
# 以下配置会覆盖 GATE_PAY_ENV 的预设值
# 通常不需要手动配置，除非需要连接自定义服务

# OAuth 配置
# GATE_PAY_OAUTH_CLIENT_ID=custom-client-id
# GATE_PAY_OAUTH_CLIENT_SECRET=custom-client-secret
# GATE_PAY_OAUTH_BACKEND_ORIGIN=custom-oauth-backend-url
# GATE_PAY_ACCOUNT_AUTHORIZE_ORIGIN=custom-account-authorize-url
# GATE_PAY_OAUTH_CALLBACK_PORT=18473
# GATE_PAY_OAUTH_SCOPE=read_profile
# GATE_PAY_OAUTH_AUTHORIZE_USER_AGENT=gateio/web

# 中心化支付配置
# GATE_PAY_CENTRALIZED_PAYMENT_URL=custom-payment-url
# GATE_PAY_CLIENT_ID=custom-payment-client-id

# 钱包服务配置
# QUICK_WALLET_SERVER_URL=custom-quick-wallet-url
# PLUGIN_WALLET_SERVER_URL=custom-plugin-wallet-url

# -----------------------------------------------------------------------------
# 测试相关（仅用于开发测试）
# -----------------------------------------------------------------------------
# RESOURCE_SERVER_URL=http://localhost:8080
# ENDPOINT_PATH=/flight/order
# GATEPAY_MCP_TEST_TIMEOUT_MS=180000
