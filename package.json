{
  "name": "gatepay-local-mcp",
  "version": "1.0.4",
  "description": "Gatepay Local (stdio) MCP server",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "gatepay-mcp": "dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "test:unit": "node --import tsx --test test/**/*.test.ts",
    "test:privateKey": "tsx test/privateKey.ts",
    "test:getTools": "tsx test/getTools.ts",
    "test:pluginWallet": "tsx test/pluginWallet.ts",
    "test:quickWallet": "tsx test/quickWallet.ts",
    "test:mcp-tool": "tsx test/mcp-x402-request-tool.ts",
    "test:split-tools": "tsx test/split-tools.test.ts",
    "test:wallet-mcp": "tsx test/wallet-mcp-auth.ts",
    "test:device-flow-login": "tsx test/device-flow-login.ts",
    "test:signer-mcp": "tsx test/signer-mcp-wallet.ts",
    "test:sol-test": "tsx test/sol-test.ts",
    "example:solana": "tsx examples/solana-payment-example.ts",
    "format": "prettier -c .prettierrc --write \"**/*.{ts,js,cjs,json,md}\"",
    "format:check": "prettier -c .prettierrc --check \"**/*.{ts,js,cjs,json,md}\"",
    "lint": "eslint . --fix",
    "lint:check": "eslint ."
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@noble/secp256k1": "^2.2.0",
    "@scure/base": "^2.0.0",
    "@solana-program/compute-budget": "^0.15.0",
    "@solana-program/token": "^0.12.0",
    "@solana-program/token-2022": "^0.9.0",
    "@solana/kit": "^6.5.0",
    "@x402/core": "^2.8.0",
    "@x402/evm": "^2.8.0",
    "@x402/svm": "^2.8.0",
    "dotenv": "^16.4.7",
    "viem": "^2.39.0"
  },
  "keywords": [
    "x402",
    "mcp",
    "payment",
    "stdio",
    "model-context-protocol"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.24.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.24.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.9",
    "eslint-plugin-prettier": "^5.2.6",
    "globals": "^15.14.0",
    "prettier": "3.5.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "homepage": "https://github.com/gate/gatepay-local-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/gate/gatepay-local-mcp"
  }
}
