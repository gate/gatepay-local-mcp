{
  "name": "gatepay-local-mcp",
  "version": "1.0.3",
  "description": "Gatepay Local (stdio) MCP server",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "bin": {
    "gatepay-mcp": "dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build",
    "start": "tsx src/index.ts",
    "dev": "tsx src/index.ts",
    "test:unit": "node --import tsx --test test/**/*.test.ts",
    "test:privateKey": "tsx test/privateKey.ts",
    "test:getTools": "tsx test/mcpclient.ts",
    "test:pluginWallet": "tsx test/pluginWallet.ts",
    "test:mcp-tool": "tsx test/mcp-x402-request-tool.ts",
    "test:wallet-mcp": "tsx test/wallet-mcp-auth.ts",
    "test:device-flow-login": "tsx test/device-flow-login.ts",
    "test:signer-mcp": "tsx test/signer-mcp-wallet.ts",
    "format": "prettier -c .prettierrc --write \"**/*.{ts,js,cjs,json,md}\"",
    "format:check": "prettier -c .prettierrc --check \"**/*.{ts,js,cjs,json,md}\"",
    "lint": "eslint . --fix",
    "lint:check": "eslint ."
  },
  "dependencies": {
    "@noble/secp256k1": "^2.2.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "dotenv": "^16.4.7",
    "viem": "^2.39.0"
  },
  "keywords": [
    "x402",
    "mcp",
    "payment",
    "stdio",
    "model-context-protocol"
  ],
  "license": "MIT",
  "devDependencies": {
    "globals": "^15.14.0",
    "@types/node": "^22.0.0",
    "@eslint/js": "^9.24.0",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "eslint": "^9.24.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsdoc": "^50.6.9",
    "eslint-plugin-prettier": "^5.2.6",
    "prettier": "3.5.2",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },  
  "homepage": "https://github.com/gate/gatepay-local-mcp",
  "repository": {
    "type": "git",
    "url": "https://github.com/gate/gatepay-local-mcp"
  }
}